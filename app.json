{
  "expo": {
    "name": "V3locity",
    "slug": "v3locity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "v3locity",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1114"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.v3locity.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "V3locity uses your location to calculate speed, distance, heading, and trip history for active trips.",
        "NSLocationAlwaysUsageDescription": "V3locity uses your location to calculate speed, distance, heading, and trip history for active trips.",
        "NSLocationWhenInUseUsageDescription": "V3locity uses your location to calculate speed, distance, heading, and trip history while the app is open.",
        "NSMotionUsageDescription": "This app uses motion sensors to improve speed accuracy."
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#00000000",
      "barStyle": "light-content",
      "translucent": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.v3locity.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-system-ui",
        {
          "backgroundColor": "#0F1114"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
