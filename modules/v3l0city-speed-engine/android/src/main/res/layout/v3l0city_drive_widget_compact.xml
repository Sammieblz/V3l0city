<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/driveWidgetRoot"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/v3l0city_drive_widget_background"
  android:gravity="center_vertical"
  android:orientation="vertical"
  android:padding="12dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:fontFamily="sans-serif-medium"
      android:maxLines="1"
      android:text="V3l0city"
      android:textColor="#EAEFF2"
      android:textSize="12sp" />

    <TextView
      android:id="@+id/driveWidgetSignalDot"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="●"
      android:textColor="#00E5FF"
      android:textSize="13sp" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="center"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/driveWidgetSpeed"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:fontFamily="sans-serif-condensed"
      android:includeFontPadding="false"
      android:maxLines="1"
      android:text="0"
      android:textColor="#FFFFFF"
      android:textSize="44sp" />

    <TextView
      android:id="@+id/driveWidgetUnits"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="5dp"
      android:fontFamily="sans-serif-medium"
      android:maxLines="1"
      android:text="MPH"
      android:textColor="#8A8F98"
      android:textSize="12sp" />
  </LinearLayout>

  <TextView
    android:id="@+id/driveWidgetStatus"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:ellipsize="end"
    android:fontFamily="sans-serif-medium"
    android:maxLines="1"
    android:text="Ready"
    android:textColor="#00E5FF"
    android:textSize="10sp" />

  <ProgressBar
    android:id="@+id/driveWidgetSpeedProgress"
    style="?android:attr/progressBarStyleHorizontal"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />

  <ImageView
    android:id="@+id/driveWidgetSpeedDial"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />

  <ImageView
    android:id="@+id/driveWidgetCompass"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />

  <TextView
    android:id="@+id/driveWidgetDistance"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />
  <TextView
    android:id="@+id/driveWidgetAverage"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />
  <TextView
    android:id="@+id/driveWidgetMax"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />
  <TextView
    android:id="@+id/driveWidgetHeading"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />
  <TextView
    android:id="@+id/driveWidgetElapsed"
    android:layout_width="1dp"
    android:layout_height="1dp"
    android:visibility="invisible" />
</LinearLayout>
